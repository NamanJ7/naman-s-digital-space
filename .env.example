# --- Contact form (Resend) ---
# Create a free account at https://resend.com and paste an API key here.
# If this is left blank, the contact form still "works" in development:
# submissions are logged to the server console instead of emailed.
RESEND_API_KEY=

# Where contact-form submissions are delivered.
CONTACT_TO_EMAIL=pjain1976@gmail.com

# The "from" address Resend sends as.
# Use the Resend sandbox address until you verify your own domain.
CONTACT_FROM_EMAIL=onboarding@resend.dev
